# Frontend Configuration - LOCAL DEVELOPMENT
# Copy this to .env.local and customize for your local environment

# Stellar Network Configuration - TESTNET
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
VITE_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Vault Contract ID - REPLACE WITH YOUR LOCAL/TESTNET CONTRACT ID
VITE_VAULT_CONTRACT_ID=

# Feature Flags - LOCAL
VITE_FF_ANALYTICS_PAGE=true
VITE_FF_ADVANCED_CHARTS=true
VITE_FF_DEBUG_MODE=true

# Backend API URL - LOCAL
VITE_API_BASE_URL=http://localhost:3000

# Optional: Sentry Configuration - LOCAL (leave VITE_SENTRY_DSN blank to disable)
# VITE_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# VITE_SENTRY_ENVIRONMENT=local
# VITE_SENTRY_TRACES_SAMPLE_RATE=1.0
# VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
# VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0
